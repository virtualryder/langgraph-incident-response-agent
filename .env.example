# ────────────────────────────────────────────────────────────────────────────
# Incident Response Agent — environment variables
# Copy to .env and fill in. NEVER commit .env.
# ────────────────────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional — LangSmith observability ─────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=incident-response-agent

# ── Optional — Live tool integrations (simulated if not set) ───────────────
GITHUB_TOKEN=ghp_...          # For live GitHub queries
AWS_ACCESS_KEY_ID=...         # For live CloudWatch queries
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1
SPLUNK_HOST=splunk.agency.gov # For live Splunk queries
SPLUNK_TOKEN=...

# ── Optional — Persistence overrides ───────────────────────────────────────
# Set these in production (Railway/ECS/K8s) to point at a mounted persistent
# volume so audit logs and the Chroma knowledge base survive redeploys.
# AUDIT_LOG_DIR=/data/audit
# CHROMA_PERSIST_DIR=/data/chroma
